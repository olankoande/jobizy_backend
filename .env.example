# Application
NODE_ENV=development
PORT=3001
APP_BASE_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3003

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=jobizy
DB_USER=root
DB_PASSWORD=
DB_CONNECTION_LIMIT=10

# Auth / JWT
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
ADMIN_EMAILS=admin@jobizy.local

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3003,http://localhost:5173,http://localhost:3000
CORS_ALLOW_CREDENTIALS=true

# Google OAuth
GOOGLE_CLIENT_ID=change-me-google-client-id
GOOGLE_CLIENT_SECRET=change-me-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback

# Stripe
STRIPE_SECRET_KEY=sk_test_change_me
STRIPE_PUBLISHABLE_KEY=pk_test_change_me
STRIPE_WEBHOOK_SECRET=whsec_change_me
STRIPE_CURRENCY=CAD

# Email / Resend
EMAIL_PROVIDER=resend
RESEND_API_KEY=change-me
EMAIL_FROM=no-reply@jobizy.local
MAIL_FROM_NAME=Jobizy
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=change-me
SMTP_PASSWORD=change-me

# Web Push / VAPID
# Generate keys with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=change-me-vapid-public-key
VAPID_PRIVATE_KEY=change-me-vapid-private-key
VAPID_SUBJECT=mailto:admin@jobizy.local

# Optional external services
DIRECTUS_URL=http://localhost:8055
DIRECTUS_TOKEN=change-me
